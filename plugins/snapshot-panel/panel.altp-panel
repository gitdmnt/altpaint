panel {
  id: "builtin.snapshot-panel"
  title: "Snapshots"
  version: 1
}

permissions {
  read.document
  service.snapshot
}

runtime {
  wasm: "builtin_panel_snapshot_panel.wasm"
}

state {
  title: string = ""
  page_count: int = 0
  panel_count: int = 0
  active_tool: string = ""
  storage_status: string = ""
  snapshot_count: int = 0
}

view {
  <column gap=8 padding=8>
    <section title="Current">
      <text tone="muted">Hosted via Rust SDK + Wasm</text>
      <text>{state.title}</text>
      <text>{state.page_count}</text>
      <text>{state.panel_count}</text>
      <text>{state.active_tool}</text>
    </section>
    <section title="Status">
      <text>{state.storage_status}</text>
    </section>
    <section title="Snapshots">
      <text>{state.snapshot_count} snapshot(s)</text>
      <button id="snapshot.create" on:click="create_snapshot">Create Snapshot</button>
    </section>
  </column>
}
