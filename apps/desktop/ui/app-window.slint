import {
    Button,
    VerticalBox,
    HorizontalBox,
    ScrollView,
} from "std-widgets.slint";

export struct PanelItem {
    kind: string,
    title: string,
    text: string,
    command: string,
    active: bool,
}

export struct PanelData {
    id: string,
    title: string,
    items: [PanelItem],
}

export component AppWindow inherits Window {
    in property <[PanelData]> panels;
    in property <image> canvas_image;
    in-out property <string> status_text: "Ready";
    callback panel_command(command: string);
    callback canvas_pointer(action: string, x: int, y: int, width: int, height: int);

    width: 1280px;
    height: 800px;
    title: "altpaint";

    HorizontalBox {
        Rectangle {
            width: 280px;
            background: #2a2a2a;
            ScrollView {
                height: 100%;
                VerticalBox {
                    padding: 8px;
                    spacing: 8px;
                    for panel in root.panels: Rectangle {
                        background: #1f1f1f;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #3f3f3f;
                        VerticalBox {
                            padding: 8px;
                            spacing: 6px;
                            Text {
                                text: panel.title;
                                color: white;
                                font-size: 18px;
                            }

                            for item in panel.items: VerticalBox {
                                if item.kind == "button": Button {
                                    text: item.active ? item.text + " *" : item.text;
                                    clicked => {
                                        root.panel_command(item.command);
                                    }
                                }
                                if item.kind == "text": Text {
                                    text: item.text;
                                    color: #d8d8d8;
                                    wrap: word-wrap;
                                }
                                if item.kind == "section": Rectangle {
                                    background: transparent;
                                    VerticalBox {
                                        spacing: 4px;
                                        Text {
                                            text: item.title;
                                            color: #9fb7ff;
                                            font-size: 15px;
                                        }

                                        Text {
                                            text: item.text;
                                            color: #d8d8d8;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            background: #606060;
            VerticalBox {
                padding: 8px;
                spacing: 8px;
                Text {
                    text: "Canvas host (WGPU direct rendering active on this surface)";
                    color: white;
                }

                Rectangle {
                    background: #404040;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #2a2a2a;
                    min-height: 640px;
                    min-width: 640px;
                    Image {
                        source: root.canvas_image;
                        width: parent.width;
                        height: parent.height;
                        image-fit: contain;
                    }

                    touch-area := TouchArea {
                        mouse-cursor: crosshair;
                        moved => {
                            if self.pressed {
                                root.canvas_pointer("drag", self.mouse-x / 1px, self.mouse-y / 1px, self.width / 1px, self.height / 1px);
                            }
                        }
                        clicked => {
                            root.canvas_pointer("down", self.mouse-x / 1px, self.mouse-y / 1px, self.width / 1px, self.height / 1px);
                            root.canvas_pointer("up", self.mouse-x / 1px, self.mouse-y / 1px, self.width / 1px, self.height / 1px);
                        }
                        pointer-event(event) => {
                            if event.kind == PointerEventKind.down {
                                root.canvas_pointer("down", self.mouse-x / 1px, self.mouse-y / 1px, self.width / 1px, self.height / 1px);
                            } else if event.kind == PointerEventKind.up {
                                root.canvas_pointer("up", self.mouse-x / 1px, self.mouse-y / 1px, self.width / 1px, self.height / 1px);
                            }
                        }
                    }
                }

                Text {
                    text: root.status_text;
                    color: #d8d8d8;
                }
            }
        }
    }
}
